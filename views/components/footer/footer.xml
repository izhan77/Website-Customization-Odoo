<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Main Footer -->
    <template id="footer_custom" inherit_id="website.layout" name="Custom Footer">
        <xpath expr="//div[@id='footer']" position="replace">
            <footer id="custom_footer" class="bg-white border-t border-gray-200 py-10">
                <div class="container mx-auto px-4 md:px-8 grid grid-cols-1 md:grid-cols-4 gap-8">

                    <t t-call="website_customizations.footer_base"/>
                    <t t-call="website_customizations.footer_company"/>
                    <t t-call="website_customizations.footer_resources"/>
                    <t t-call="website_customizations.footer_social"/>

                </div>

                <t t-call="website_customizations.footer_bottom"/>
            </footer>
        </xpath>
    </template>
</odoo>
